# Normaliza saltos de línea. El script gradlew DEBE quedar en LF para que el
# build en GitHub Actions (Linux) no falle.
* text=auto eol=lf
*.bat   text eol=crlf
gradlew text eol=lf
*.sh    text eol=lf

# Binarios (no tocar)
*.jar   binary
*.png   binary
*.jpg   binary
*.svg   binary
*.pdf   binary
*.keystore binary
